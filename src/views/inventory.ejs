<%- include('partials/header') %>
<main>
    <div class="inventory-title">
        <h1>Inventory Page</h1>
        <p>Come look at our inventory of vehicles!</p>
        <div class="category-filters">
            <form action="/inventory" method="GET">
                <label for="category-select">Filter by category:</label>
                <select name="category" id="category-select" onchange="this.form.submit()">
                    <option value="" <%= !selectedCategory ? 'selected' : '' %>>All</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.name %>" <%= selectedCategory === cat.name ? 'selected' : '' %>>
                            <%= cat.name %>
                        </option>
                    <% }); %>
                </select>
            </form>
        </div>
        <div class="vehicle-grid">
            <% vehicles.forEach(vehicle => { %>
                <div class="vehicle-card">
                    <img src="<%= vehicle.image_url || '/images/vehicles/imageComingSoon.jpg' %>"
                        alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>"
                        class="vehicle-image">
                    <h2><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h2>
                    <p class="text-secondary"> <%= vehicle.category_name || 'Uncategorized' %></p>
                    <p>$<%= vehicle.price %></p>
                    <p><%= vehicle.description %></p>
                </div>
            <% }); %>
        </div>
    </div>
</main>
<%- include('partials/footer') %>